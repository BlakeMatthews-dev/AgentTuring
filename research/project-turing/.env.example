# Project Turing runtime configuration.
# Copy to .env and fill in. .env is git-ignored; never commit it.

# --- Reactor ---
# Ticks per second. 100 is fine for a research box; 1000 matches main.
TURING_TICK_RATE_HZ=100
TURING_EXECUTOR_WORKERS=8

# --- Storage ---
# Path inside the container. A Docker volume mounts at /data.
TURING_DB_PATH=/data/turing.db

# --- Logging / observability ---
TURING_LOG_LEVEL=INFO
TURING_LOG_FORMAT=json
TURING_METRICS_PORT=9100

# --- Providers ---
# Comma-separated: fake,gemini,openrouter,zai
TURING_PROVIDERS=fake

# Required when TURING_PROVIDERS includes gemini:
# GEMINI_API_KEY=

# Required when TURING_PROVIDERS includes zai:
# ZAI_API_KEY=

# OpenRouter stays on FakeProvider until someone ports runtime/providers/
# openrouter.py along the same lines as gemini.py / zai.py.
# OPENROUTER_API_KEY=

# --- Workload ---
# Name (resolved against /app/scenarios/<name>.yaml) or absolute path.
TURING_SCENARIO=baseline

# --- Identity ---
# Labels the self_id persists under. Change at your peril — operating the
# system under a new self_label is how you start a fresh research instance.
TURING_SELF_LABEL=default
