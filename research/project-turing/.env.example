# Project Turing runtime configuration.
# Copy to .env and fill in. .env is git-ignored; never commit it.

# --- Reactor ---
TURING_TICK_RATE_HZ=100
TURING_EXECUTOR_WORKERS=8

# --- Storage ---
TURING_DB_PATH=/data/turing.db
TURING_JOURNAL_DIR=/data/journal

# --- Logging / observability ---
TURING_LOG_LEVEL=INFO
TURING_LOG_FORMAT=json
TURING_METRICS_PORT=9100
TURING_METRICS_BIND=127.0.0.1     # set 0.0.0.0 to expose externally

# --- Providers (LiteLLM) ---
# Project Turing uses your LiteLLM proxy for everything. One virtual key,
# one base URL, one pools.yaml describing which models to consume.
#
# To run without LiteLLM (local fake provider only):
TURING_USE_FAKE_PROVIDER=true

# To run with LiteLLM (recommended):
# TURING_USE_FAKE_PROVIDER=false
# LITELLM_BASE_URL=http://litellm:4000
# LITELLM_VIRTUAL_KEY=sk-...
# TURING_POOLS_CONFIG=/app/config/pools.yaml

# --- Workload ---
TURING_SCENARIO=baseline

# --- Identity ---
TURING_SELF_LABEL=default
