# Stronghold environment variables
# Copy to .env and fill in real values
# NEVER commit .env — it's in .gitignore

# --- Stronghold ---
ROUTER_API_KEY=sk-example-stronghold
DATABASE_URL=postgresql://stronghold:stronghold@localhost:5432/stronghold

# --- LiteLLM ---
LITELLM_URL=http://litellm:4000
LITELLM_MASTER_KEY=sk-example-litellm

# --- LLM Provider API Keys (set the ones you use) ---
MISTRAL_API_KEY=
CEREBRAS_API_KEY=
GOOGLE_API_KEY=

# --- Arize Phoenix (local dev) ---
PHOENIX_COLLECTOR_ENDPOINT=http://phoenix:6006

# --- Arize Enterprise (production) ---
# ARIZE_API_KEY=
# ARIZE_SPACE_KEY=

# --- Auth: Keycloak ---
# KEYCLOAK_ISSUER=https://sso.example.com/realms/stronghold
# KEYCLOAK_AUDIENCE=stronghold

# --- Auth: Entra ID ---
# ENTRA_TENANT_ID=
# ENTRA_CLIENT_ID=

# --- MCP Servers ---
# HA_MCP_URL=http://ha-mcp-server:8080
# SEARCH_MCP_URL=http://search-mcp-server:8081
